<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cyber Incident Response - Authorization Terminal</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: #00ff00;
            font-family: 'Courier New', 'Courier', monospace;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }

        /* Terminal scanning animation */
        @keyframes scanlines {
            0% {
                transform: translateY(0);
            }
            100% {
                transform: translateY(10px);
            }
        }

        @keyframes glitch {
            0%, 100% {
                text-shadow: 2px 0 #ff00ff, -2px 0 #00ffff;
            }
            50% {
                text-shadow: -2px 0 #ff00ff, 2px 0 #00ffff;
            }
        }

        @keyframes blink {
            0%, 49% {
                opacity: 1;
            }
            50%, 100% {
                opacity: 0;
            }
        }

        @keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 10px rgba(0, 255, 0, 0.3), inset 0 0 10px rgba(0, 255, 0, 0.1);
            }
            50% {
                box-shadow: 0 0 20px rgba(0, 255, 0, 0.6), inset 0 0 10px rgba(0, 255, 0, 0.2);
            }
        }

        .scanlines::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 255, 0, 0.03),
                rgba(0, 255, 0, 0.03) 1px,
                transparent 1px,
                transparent 2px
            );
            pointer-events: none;
            z-index: 1;
            animation: scanlines 8s linear infinite;
        }

        .container {
            position: relative;
            z-index: 2;
            background: rgba(10, 20, 40, 0.9);
            border: 3px solid #00ff00;
            border-radius: 5px;
            padding: 40px;
            box-shadow: 
                0 0 20px rgba(0, 255, 0, 0.5),
                inset 0 0 20px rgba(0, 255, 0, 0.1),
                0 0 40px rgba(0, 255, 0, 0.2);
            max-width: 600px;
            width: 100%;
            animation: pulse-glow 3s ease-in-out infinite;
        }

        header {
            text-align: center;
            margin-bottom: 30px;
        }

        .status-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            background-color: #ff0000;
            border-radius: 50%;
            margin-right: 10px;
            animation: pulse 1s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
                box-shadow: 0 0 5px #ff0000, 0 0 10px #ff0000;
            }
            50% {
                opacity: 0.7;
                box-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000;
            }
        }

        .system-status {
            font-size: 14px;
            margin-bottom: 10px;
            color: #00ff00;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h1 {
            font-size: 32px;
            font-weight: bold;
            margin: 15px 0;
            letter-spacing: 3px;
            color: #00ff00;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.8);
        }

        @media (max-width: 600px) {
            h1 {
                font-size: 24px;
            }
        }

        .timestamp {
            font-size: 12px;
            color: #00aa00;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .story-text {
            background: rgba(0, 0, 0, 0.5);
            border-left: 3px solid #00ff00;
            padding: 20px;
            margin: 20px 0;
            font-size: 14px;
            line-height: 1.6;
            color: #00ff00;
        }

        .story-text p {
            margin-bottom: 10px;
        }

        .story-text p:last-child {
            margin-bottom: 0;
        }

        .input-group {
            margin: 30px 0;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #00ff00;
        }

        input[type="text"] {
            background: rgba(0, 0, 0, 0.8);
            border: 2px solid #00ff00;
            color: #00ff00;
            font-family: 'Courier New', monospace;
            font-size: 18px;
            padding: 12px 15px;
            border-radius: 3px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 2px;
            box-shadow: inset 0 0 10px rgba(0, 255, 0, 0.1);
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #00ffff;
            box-shadow: 
                inset 0 0 10px rgba(0, 255, 0, 0.2),
                0 0 15px rgba(0, 255, 255, 0.5);
            color: #00ffff;
        }

        input[type="text"]::placeholder {
            color: #007700;
        }

        .button-group {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        button {
            background: rgba(0, 255, 0, 0.1);
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 12px 30px;
            font-size: 14px;
            font-family: 'Courier New', monospace;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            border-radius: 3px;
            transition: all 0.3s ease;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        button:hover {
            background: rgba(0, 255, 0, 0.2);
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.6);
            transform: scale(1.05);
        }

        button:active {
            transform: scale(0.98);
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .clear-btn {
            background: rgba(255, 0, 0, 0.1);
            border-color: #ff6666;
            color: #ff6666;
            box-shadow: 0 0 10px rgba(255, 100, 100, 0.3);
        }

        .clear-btn:hover {
            background: rgba(255, 0, 0, 0.2);
            box-shadow: 0 0 20px rgba(255, 100, 100, 0.6);
        }

        .response-area {
            margin-top: 30px;
            min-height: 80px;
            display: none;
            background: rgba(0, 0, 0, 0.8);
            border: 2px solid #00ff00;
            padding: 20px;
            border-radius: 3px;
            box-shadow: inset 0 0 10px rgba(0, 255, 0, 0.1);
        }

        .response-area.show {
            display: block;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .response-status {
            font-size: 18px;
            font-weight: bold;
            letter-spacing: 2px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .status-granted {
            color: #00ff00;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.8);
        }

        .status-denied {
            color: #ff0000;
            text-shadow: 0 0 10px rgba(255, 0, 0, 0.8);
        }

